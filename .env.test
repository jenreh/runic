# Test backends — comma-separated list of backends to run integration tests against.
# All backends require docker-compose.test.yml to be running (except falkordb which
# uses the embedded redislite process). Unreachable backends are skipped automatically.
RUNIC_TEST_BACKENDS=falkordb,neo4j,memgraph,age,arcadedb
# RUNIC_TEST_BACKENDS=arcadedb

# Neo4j (docker-compose service: neo4j, NEO4J_AUTH: none)
RUNIC_NEO4J_URI=bolt://localhost:7687

# Memgraph (docker-compose service: memgraph, host port 7688)
RUNIC_MEMGRAPH_URI=bolt://localhost:7688

# ArcadeDB (docker-compose service: arcadedb)
RUNIC_ARCADEDB_HOST=localhost
RUNIC_ARCADEDB_PORT=2424
RUNIC_ARCADEDB_PASSWORD=playwithdata

# Apache AGE / PostgreSQL (docker-compose service: age)
RUNIC_AGE_HOST=localhost
RUNIC_AGE_PORT=5432
RUNIC_AGE_PASSWORD=postgres
